# App Factory Environment Variables
# Copy to .env and fill in values. Never commit secrets.

# ── State & Storage ──────────────────────────────────────
APP_FACTORY_STATE_DIR=./app-factory/state
APP_FACTORY_PROJECTS_DIR=./app-factory/projects
APP_FACTORY_LOGS_DIR=./app-factory/logs

# ── Dashboard ────────────────────────────────────────────
DASHBOARD_API_PORT=3002
DASHBOARD_API_HOST=127.0.0.1
DASHBOARD_PASSPHRASE=change-this-passphrase
NEXT_PUBLIC_API_URL=http://localhost:3002

# ── External Services (optional — stubs used if absent) ──

# Nano Banana Pro (icon generation)
# NANO_BANANA_PRO_API_KEY=your-key
# NANO_BANANA_PRO_API_URL=https://api.nanobananapro.com/v1

# Votion (video generation)
# VOTION_API_KEY=your-key
# VOTION_API_URL=https://api.votion.io/v1

# App Store Connect
# APP_STORE_CONNECT_KEY_ID=your-key-id
# APP_STORE_CONNECT_ISSUER_ID=your-issuer-id
# APP_STORE_CONNECT_PRIVATE_KEY_PATH=./keys/AuthKey.p8

# ── Larry Marketing (separate credential namespace) ─────
# X (Twitter)
# LARRY_X_API_KEY=your-key
# LARRY_X_API_SECRET=your-secret
# LARRY_X_ACCESS_TOKEN=your-token
# LARRY_X_ACCESS_SECRET=your-access-secret

# Reddit
# LARRY_REDDIT_CLIENT_ID=your-id
# LARRY_REDDIT_CLIENT_SECRET=your-secret
# LARRY_REDDIT_USERNAME=your-username
# LARRY_REDDIT_PASSWORD=your-password

# TikTok
# LARRY_TIKTOK_ACCESS_TOKEN=your-token

# Instagram
# LARRY_INSTAGRAM_ACCESS_TOKEN=your-token
# LARRY_INSTAGRAM_BUSINESS_ID=your-business-id
